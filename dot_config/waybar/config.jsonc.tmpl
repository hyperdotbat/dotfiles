// -*- mode: jsonc -*-
{
    "layer": "top",
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 30, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    "spacing": 20, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/submap"
        // "niri/workspaces"
        // "hyprland/window",
        // "custom/media",
        // "mpd"
        // "group/mpd"
    ],
    "modules-center": [
        //"hyprland/window"
	    "clock"
    ],
    "modules-right": [
        // "group/mpd-vertical",
        // "idle_inhibitor",
        // "power-profiles-daemon",

	{{- if eq .chezmoi.hostname "hoshizora" }}
        "cpu",
        // "memory",
        "temperature",
        "hyprland/language",
	{{- end }}

        "backlight",
        "battery",
        // "battery#bat1",
        //"clock",
        "pulseaudio",
        "network",
        // "tray",
        "group/minimized",
        "custom/power"
    ],
    // Modules configuration
    "hyprland/workspaces": {
        "DP-2": [ 1, 2, 3, 4, 5 ],
        // "DP-1": [ 6, 7, 8, 9, 10 ],
	    "show-special": true,
        //"all-outputs": true,
        "move-to-monitor": true,
        "warp-on-scroll": false,
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        // "format": "{name} {icon}",
        // "format": "{name} {windows}",
	
	{{- if eq .chezmoi.hostname "pakku" }}
        "format": "{name}",
	{{- else }}
        "format": "{icon} {windows}",
	{{- end }}

        "format-icons": {
            "1": "1",//"1 ’ē® ",
            "2": "2",//"2 ’äĀ ",
            "3": "3",//"3 ’äĪ ",
            "4": "4",//"4 ’äø ",
            "5": "5",//"5 ’üĄ ",
            "6": "6",//"6",//"6 Ņł╝ ",
            "7": "7",//"7",
            "8": "8",//"8",
            "9": "9",//"9",
            "10": "0",//"0",
            // "urgent": "’ü¬ ",
            // "focused": "’åÆ ",
            // "default": "",//"’äæ ",
            // "special": "Ōśå" ,
            "dc": "",//"¾░Ö» ",
            "spc": "",//"’å╝ ",
            "gpt": "",//"¾░Ü® ",
        },
        "workspace-taskbar": {
            "enable": true,
            "format": "{icon}",
            "icon-size": 16,
            // "icon-theme": "breeze"
        },
    },
    "hyprland/window": {
        "separate-outputs": true,
	    // "format": "<span rise='-4444'>{title}</span>",
        // "icon": true
    },
    "hyprland/submap": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) ŌĖ©{songPosition}|{queueLength}ŌĖ® {volume}% ’Ćü ",
        "format-disconnected": "Disconnected ’Ćü ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped ’Ćü ",
        "unknown-tag": "N/A",
        "interval": 5,
        "consume-icons": {
            "on": "’āä "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">’ü┤</span> ",
            "on": "’ü┤ "
        },
        "repeat-icons": {
            "on": "’Ć× "
        },
        "single-icons": {
            "on": "’Ć×1 "
        },
        "state-icons": {
            "paused": "’üī",
            "playing": "’üŗ"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "custom/media": {
        // "format": "{icon} {text}",
        "format": "{text}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            // "spotify": "’å╝ ",
            "default": "­¤Ä£"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    },
    "clock": {
        // "timezone": "Europe/Warsav",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "{:%H:%M | %Y-%m-%d}",
	    "on-click": "$HOME/.config/hypr/scripts-assets-hypr/rofi-launcher.sh",
	    "on-click-right": "gnome-calendar",
	    "on-click-middle": "gnome-weather"
    },
    "idle_inhibitor": {
        "format": "{icon}", // added space for spacing in the minimized group
        "format-icons": {
            "activated": "’ü« ",
            "deactivated": "’ü░ "
        }
    },
    "cpu": {
        "format": "{usage}% ’ŗø ",
        // "tooltip": false,
        "tooltip-format": "{usage}",
        "on-click": "$HOME/.config/hypr/scripts-assets-hypr/screenshot-grimblast.sh area",
        "on-click-right": "$HOME/.config/hypr/scripts-assets-hypr/screenshots-dir-open.sh"
    },
    "memory": {
        "format": "{}% ’āē ",
        "on-click": "$HOME/.config/hypr/scripts-assets-hypr/screenshot-grimblast.sh area",
        "on-click-right": "$HOME/.config/hypr/scripts-assets-hypr/screenshots-dir-open.sh"
    },
    "temperature": {
        // "thermal-zone": 2,
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "tooltip": false,
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["’Ø½", "’ŗē", "’Ø®"],
        "on-click": "control",
        "on-click-right": "$HOME/.config/hypr/scripts-assets-hypr/open-task-manager.sh",
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["ŅÄŹ", "ŅÅō", "ŅÅæ", "ŅÅÅ", "ŅÅÄ", "ŅÅŹ", "ŅÅŖ", "ŅÅł", "ŅÄø"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-full": "{capacity}% {icon}",
        "format-charging": "{capacity}% ’Ś¦",
        "format-plugged": "{capacity}% ’ć”",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "power-profiles-daemon": {
        "format": "{icon}", // added space for spacing in the minimized group
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "’ā¦ ",
            "performance": "’ā¦ ",
            "balanced": "’ēÄ ",
            "power-saver": "’ü¼ "
        },
        "on-click-right": "control"
    },
    "hyprland/language": {
        "format": "’ä£  {}",
        "format-en": "EN",
        "format-pl": "PL",
        "format-jp": "JP",
        "on-click": "",
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        // "format-wifi": "{essid} ({signalStrength}%) ’ć½ ",
        "format-wifi": "({signalStrength}%) ’ć½ ",
        // "format-ethernet": "{ipaddr}/{cidr} ’×¢ ",
        "format-ethernet": "’×¢",
        // "tooltip-format": "{ifname} via {gwaddr} ’×¢ ",
        "tooltip-format": "{ipaddr}/{cidr}\n{ifname} via {gwaddr} ’×¢ ",
        "format-linked": "(No IP) ’×¢ ",
        "format-disconnected": "Disconnected ŌÜĀ ",
        "format-alt": "{ifname}: {essid}",
        "on-click-right": "nm-connection-editor"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
	    // "max-volume": 150,
        "format": "{volume}% {icon} {format_source} ",
        // "format": "{volume}% {icon} ",
        "format-bluetooth": "{volume}% {icon}’Ŗö {format_source} ",
        // "format-bluetooth-muted": "’Ü® {icon}’Ŗö {format_source}",
        "format-bluetooth-muted": "{volume}% ’Ü® {icon}’Ŗö {format_source} ",
        "format-muted": "{volume}% ’Ü® {format_source} ",
        // "format-muted": "’Ü®",
        // "format-source": "{volume}% ’ä░",
        "format-source": "’ä░",
        "format-source-muted": "’ä▒",
        "format-icons": {
            "headphone": "’Ćź ",
            "hands-free": "’¢É ",
            "headset": "’¢É ",
            "phone": "’éĢ ",
            "portable": "’éĢ ",
            "car": "’å╣ ",
            "default": ["¾░Ģ┐", "¾░¢Ć", "¾░ĢŠ"]
        },
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
        "on-scroll-up": "$HOME/.config/hypr/scripts-assets-hypr/volume-set.sh +",
        "on-scroll-down": "$HOME/.config/hypr/scripts-assets-hypr/volume-set.sh -"
    },

    "custom/expand-left": {
        "tooltip": false,
        "format": "\uf0d9",
    },
    "custom/expand-right": {
        "tooltip": false,
        "format": "\uf0da",
    },
    "custom/expand-down": {
        "tooltip": false,
        "format": "\uf0d7",
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 0,
        // "icons": {
        //   "blueman": "bluetooth",
        //   "TelegramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png"
        // }
    },
    "group/minimized": {
        "orientation": "inherit",
        // "modules": ["custom/expand", "tray"],
        "modules": ["custom/expand-left", "idle_inhibitor", "power-profiles-daemon", "tray"],
        "drawer": {
            "transition-duration": 500,
            "children-class": "minimized",
            "transition-left-to-right": false,
            "click-to-reveal": true
        }
    },

    "custom/power": {
        "format" : "ŌÅ╗",
    		"tooltip": false,
    //		"menu": "on-click",
    //		"menu-file": "$HOME/.config/waybar/power_menu.xml", // Menu file in resources folder
    //		"menu-actions": {
    //			"shutdown": "shutdown",
    //			"reboot": "reboot",
    //			"suspend": "systemctl suspend",
    //			"hibernate": "systemctl hibernate"
    //		}
    	"on-click": "$HOME/.config/hypr/scripts-assets-hypr/waybar-power-button.sh",
    	"on-click-right": "$HOME/.config/hypr/scripts-assets-hypr/suspend.sh",
    	"on-click-middle": "systemctl poweroff"
    },



    "group/mpd": {
        "orientation": "inherit",
        // "modules": ["custom/expand", "tray"],
        "modules": [ "custom/expand-right", "mpd" ],
        "drawer": {
            "transition-duration": 500,
            "children-class": "minimized",
            "transition-left-to-right": true,
            "click-to-reveal": true
        }
    },

    "group/mpd-vertical": {
        "orientation": "vertical",
        // "modules": ["custom/expand", "tray"],
        "modules": [ "custom/expand-down", "mpd" ],
        "drawer": {
            "transition-duration": 500,
            "children-class": "minimized",
            "transition-left-to-right": true,
            "click-to-reveal": true
        }
    },
}
